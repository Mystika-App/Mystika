{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/create-checkout.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/verify-payment.js": {
      "memory": 256,
      "maxDuration": 10
    }
  }
}
